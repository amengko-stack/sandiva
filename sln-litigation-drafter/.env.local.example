# ─── Authentication ───────────────────────────────────────────────────────────
# Choose any password for the shared login
APP_PASSWORD=pilih-kata-sandi-anda

# Pre-compute this with: node -e "const c=require('crypto'); console.log(c.createHmac('sha256','sln-drafter-2024').update('pilih-kata-sandi-anda').digest('hex'))"
# Or just set it to the same value as APP_PASSWORD and the login route will work
APP_SESSION_TOKEN=token-yang-dihasilkan-dari-script-di-atas

# ─── Anthropic (Claude AI) ────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Vercel Blob Storage ──────────────────────────────────────────────────────
# Get from: Vercel Dashboard → your project → Storage → Blob → Create Store → Token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# Get from: Vercel Dashboard → Storage → Blob → Store URL
BLOB_BASE_URL=https://xxxxxxxxxxxx.public.blob.vercel-storage.com

# ─── Microsoft SharePoint Write (via Graph API) ───────────────────────────────
# Create an app registration in Azure AD:
# portal.azure.com → Azure Active Directory → App registrations → New registration
# Add permission: Sites.ReadWrite.All (Application type, not Delegated)
# Grant admin consent

AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-value

# Get from Graph API Explorer: GET https://graph.microsoft.com/v1.0/sites/{hostname}:/sites/{site-name}
# Replace {hostname} with e.g. sandivalaw.sharepoint.com and {site-name} with your site name
SHAREPOINT_SITE_ID=sandivalaw.sharepoint.com,xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx,xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
